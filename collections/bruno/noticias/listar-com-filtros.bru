meta {
  name: Listar Noticias com filtros
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/noticias
  body: none
  auth: none
}

params:query {
  ~titulo: cao
  ~autor: Pedro
  ~categoria: ACESSIBILIDADE
  ~status: PUBLICADO
  ~tags: guia
  ~dataInicio: 2025-01-01T00:00:00
  ~dataFim: 2026-12-31T23:59:59
  ~page: 0
  ~size: 10
  ~sort: criadoEm,desc
}

vars:pre-request {
  baseUrl: http://localhost:8080
}
