{
  "info": {
    "name": "CaoGuia API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "noticiaId", "value": "1" }
  ],
  "item": [
    {
      "name": "Noticias",
      "item": [
        {
          "name": "Criar Noticia",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/noticias", "host": ["{{baseUrl}}"], "path": ["api", "noticias"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Nova noticia sobre cao-guia\",\n  \"conteudo\": \"Conteudo completo da noticia aqui...\",\n  \"resumo\": \"Resumo curto da noticia\",\n  \"autor\": \"Pedro\",\n  \"categoria\": \"ACESSIBILIDADE\",\n  \"status\": \"RASCUNHO\",\n  \"tags\": \"cao-guia, acessibilidade\",\n  \"imagemUrl\": \"https://exemplo.com/imagem.jpg\"\n}"
            }
          }
        },
        {
          "name": "Buscar Noticia por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/noticias/{{noticiaId}}", "host": ["{{baseUrl}}"], "path": ["api", "noticias", "{{noticiaId}}"] }
          }
        },
        {
          "name": "Listar Noticias (sem filtros)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/noticias?page=0&size=10&sort=criadoEm,desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "noticias"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sort", "value": "criadoEm,desc" }
              ]
            }
          }
        },
        {
          "name": "Listar Noticias (com filtros)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/noticias?titulo=cao&autor=Pedro&categoria=ACESSIBILIDADE&status=PUBLICADO&tags=guia&dataInicio=2025-01-01T00:00:00&dataFim=2026-12-31T23:59:59&page=0&size=10&sort=criadoEm,desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "noticias"],
              "query": [
                { "key": "titulo", "value": "cao" },
                { "key": "autor", "value": "Pedro" },
                { "key": "categoria", "value": "ACESSIBILIDADE" },
                { "key": "status", "value": "PUBLICADO" },
                { "key": "tags", "value": "guia" },
                { "key": "dataInicio", "value": "2025-01-01T00:00:00" },
                { "key": "dataFim", "value": "2026-12-31T23:59:59" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sort", "value": "criadoEm,desc" }
              ]
            }
          }
        },
        {
          "name": "Atualizar Noticia",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/noticias/{{noticiaId}}", "host": ["{{baseUrl}}"], "path": ["api", "noticias", "{{noticiaId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Titulo atualizado\",\n  \"conteudo\": \"Conteudo atualizado da noticia...\",\n  \"resumo\": \"Resumo atualizado\",\n  \"autor\": \"Pedro\",\n  \"categoria\": \"TECNOLOGIA\",\n  \"status\": \"PUBLICADO\",\n  \"tags\": \"tecnologia, inovacao\",\n  \"imagemUrl\": \"https://exemplo.com/nova-imagem.jpg\"\n}"
            }
          }
        },
        {
          "name": "Atualizar Status",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/noticias/{{noticiaId}}/status?status=PUBLICADO",
              "host": ["{{baseUrl}}"],
              "path": ["api", "noticias", "{{noticiaId}}", "status"],
              "query": [{ "key": "status", "value": "PUBLICADO" }]
            }
          }
        },
        {
          "name": "Deletar Noticia",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/noticias/{{noticiaId}}", "host": ["{{baseUrl}}"], "path": ["api", "noticias", "{{noticiaId}}"] }
          }
        }
      ]
    },
    {
      "name": "Estatisticas",
      "item": [
        {
          "name": "Registrar Evento",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/estatisticas/eventos", "host": ["{{baseUrl}}"], "path": ["api", "estatisticas", "eventos"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"noticiaId\": 1,\n  \"usuarioId\": \"usuario-123\",\n  \"tipoEvento\": \"VISUALIZACAO\",\n  \"origem\": \"app\"\n}"
            }
          }
        },
        {
          "name": "Registrar Like",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/estatisticas/eventos", "host": ["{{baseUrl}}"], "path": ["api", "estatisticas", "eventos"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"noticiaId\": 1,\n  \"usuarioId\": \"usuario-123\",\n  \"tipoEvento\": \"LIKE\",\n  \"origem\": \"app\"\n}"
            }
          }
        },
        {
          "name": "Registrar Compartilhamento",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/estatisticas/eventos", "host": ["{{baseUrl}}"], "path": ["api", "estatisticas", "eventos"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"noticiaId\": 1,\n  \"usuarioId\": \"usuario-123\",\n  \"tipoEvento\": \"COMPARTILHAMENTO\",\n  \"origem\": \"web\"\n}"
            }
          }
        },
        {
          "name": "Listar Eventos (sem filtros)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/estatisticas/eventos?page=0&size=10&sort=criadoEm,desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "estatisticas", "eventos"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sort", "value": "criadoEm,desc" }
              ]
            }
          }
        },
        {
          "name": "Listar Eventos (com filtros)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/estatisticas/eventos?noticiaId=1&usuarioId=usuario-123&tipoEvento=LIKE&page=0&size=10&sort=criadoEm,desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "estatisticas", "eventos"],
              "query": [
                { "key": "noticiaId", "value": "1" },
                { "key": "usuarioId", "value": "usuario-123" },
                { "key": "tipoEvento", "value": "LIKE" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sort", "value": "criadoEm,desc" }
              ]
            }
          }
        },
        {
          "name": "Resumo por Noticia",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/estatisticas/noticias/{{noticiaId}}", "host": ["{{baseUrl}}"], "path": ["api", "estatisticas", "noticias", "{{noticiaId}}"] }
          }
        }
      ]
    }
  ]
}

