          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/usuarios/cadastro-admin", "host": ["{{baseUrl}}"], "path": ["api", "usuarios", "cadastro-admin"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Novo Admin\",\n  \"email\": \"novoadmin@caoguia.com\",\n  \"telefone\": \"62999887766\",\n  \"senha\": \"senhaSegura123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Atualizar usuário (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/usuarios/1", "host": ["{{baseUrl}}"], "path": ["api", "usuarios", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João Atualizado\",\n  \"email\": \"joao.novo@email.com\",\n  \"senha\": \"novaSenha456\"\n}",
              "options": { "raw": { "language": "json" } }
